generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  documentNumber    String             @unique @map("cedula")
  fullName          String             @map("nombre")
  email             String             @unique
  password          String
  role              Role               @default(TECNICO)
  zone              Zone               @default(BOGOTA) @map("zona")
  jobTitle          JobTitle           @default(TECNICO) @map("cargo")
  teamFilter        String             @default("TODOS") @map("filtroEquipo")
  isActive          Boolean            @default(true) @map("isActive")
  photoUrl          String?            @map("fotoUrl")
  createdAt         DateTime           @default(now()) @map("createdAt")
  updatedAt         DateTime           @updatedAt @map("updatedAt")
  availabilities    Availability[]
  tripRecords       TripRecord[]
  shiftSchedules    ShiftSchedule[]
  pushSubscriptions PushSubscription[]
  reportsCreated    Report[]           @relation("ReportesCreados")
  shifts            Shift[]
  coordinatorShifts CoordinatorShift[]

  @@map("User")
}

model Shift {
  id                         String        @id @default(cuid())
  userId                     String        @map("userId")
  date                       DateTime      @db.Date @map("fecha")
  weekday                    String?       @map("diaSemana")
  clockInAt                  DateTime      @map("horaEntrada")
  clockOutAt                 DateTime?     @map("horaSalida")
  clockInLat                 Float?        @map("latEntrada")
  clockInLng                 Float?        @map("lngEntrada")
  clockOutLat                Float?        @map("latSalida")
  clockOutLng                Float?        @map("lngSalida")
  startPhotoUrl              String?       @map("startPhotoUrl")
  endPhotoUrl                String?       @map("endPhotoUrl")
  regularHours               Float         @default(0) @map("horasOrdinarias")
  daytimeOvertimeHours       Float         @default(0) @map("heDiurna")
  nighttimeOvertimeHours     Float         @default(0) @map("heNocturna")
  sundayOvertimeHours        Float         @default(0) @map("heDominical")
  nightSundayOvertimeHours   Float         @default(0) @map("heNoctDominical")
  nightSurchargeHours        Float         @default(0) @map("recNocturno")
  sundaySurchargeHours       Float         @default(0) @map("recDominical")
  nightSundaySurchargeHours  Float         @default(0) @map("recNoctDominical")
  notes                      String?       @map("observaciones")
  workdayAlertSentAt         DateTime?     @map("jornadaAlertaPushSentAt")
  createdAt                  DateTime      @default(now()) @map("createdAt")
  updatedAt                  DateTime      @updatedAt @map("updatedAt")
  reports                    ReportShift[]
  user                       User          @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("Turno")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("userId")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("createdAt")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("PushSubscription")
}

model ShiftSchedule {
  id        String               @id @default(cuid())
  userId    String               @map("userId")
  date      DateTime             @db.Date @map("fecha")
  shiftCode String               @map("valor")
  dayType   DayType?             @default(TRABAJO) @map("tipo")
  startTime String?              @map("horaInicio")
  endTime   String?              @map("horaFin")
  createdAt DateTime             @default(now()) @map("createdAt")
  user      User                 @relation(fields: [userId], references: [id])
  reports   ReportAvailability[]

  @@unique([userId, date])
  @@map("MallaTurno")
}

model Holiday {
  id    String   @id @default(cuid())
  date  DateTime @unique @db.Date @map("fecha")
  name  String   @map("nombre")

  @@map("Festivo")
}

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("userId")
  date      DateTime @db.Date @map("fecha")
  amount    Float    @default(80000) @map("monto")
  createdAt DateTime @default(now()) @map("createdAt")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("Disponibilidad")
}

model TripRecord {
  id              String           @id @default(cuid())
  userId          String           @map("userId")
  type            String           @map("tipo")
  driveFileId     String?          @map("driveFileId")
  driveUrl        String?          @map("driveUrl")
  driveFileIdFinal String?         @map("driveFileIdFinal")
  driveUrlFinal   String?          @map("driveUrlFinal")
  base64Fallback  String?          @map("base64Fallback")
  startKm         Float?           @map("kmInicial")
  endKm           Float?           @map("kmFinal")
  startLat        Float?           @map("latInicial")
  startLng        Float?           @map("lngInicial")
  endLat          Float?           @map("latFinal")
  endLng          Float?           @map("lngFinal")
  notes           String?          @map("observaciones")
  approvalStatus  ApprovalStatus   @default(PENDIENTE) @map("estadoAprobacion")
  approvedBy      String?          @map("aprobadoPor")
  approvedAt      DateTime?        @map("fechaAprobacion")
  approvalNote    String?          @map("notaAprobacion")
  createdAt       DateTime         @default(now()) @map("createdAt")
  user            User             @relation(fields: [userId], references: [id])
  reports         ReportTrip[]

  @@map("FotoRegistro")
}

model Report {
  id                          String                    @id @default(cuid())
  name                        String                    @map("nombre")
  startDate                   DateTime                  @db.Date @map("fechaInicio")
  endDate                     DateTime                  @db.Date @map("fechaFin")
  createdBy                   String                    @map("creadoPor")
  zone                        String?                   @map("zona")
  createdAt                   DateTime                  @default(now()) @map("createdAt")
  createdByUser               User                      @relation("ReportesCreados", fields: [createdBy], references: [id])
  availabilitiesIncluded      ReportAvailability[]
  tripsIncluded               ReportTrip[]
  shiftsIncluded              ReportShift[]
  coordinatorShiftsIncluded   ReportCoordinatorShift[]

  @@index([zone])
  @@index([createdAt])
  @@map("Reporte")
}

model ReportShift {
  id        String  @id @default(cuid())
  reportId  String  @map("reporteId")
  shiftId   String  @map("turnoId")
  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  shift     Shift   @relation(fields: [shiftId], references: [id])

  @@unique([reportId, shiftId])
  @@map("ReporteTurno")
}

model ReportTrip {
  id            String     @id @default(cuid())
  reportId      String     @map("reporteId")
  tripRecordId  String     @map("fotoRegistroId")
  tripRecord    TripRecord @relation(fields: [tripRecordId], references: [id])
  report        Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, tripRecordId])
  @@map("ReporteForaneo")
}

model ReportAvailability {
  id              String        @id @default(cuid())
  reportId        String        @map("reporteId")
  shiftScheduleId String        @map("mallaTurnoId")
  shiftSchedule   ShiftSchedule @relation(fields: [shiftScheduleId], references: [id])
  report          Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, shiftScheduleId])
  @@map("ReporteDisponibilidad")
}

model CoordinatorShift {
  id                         String                    @id @default(cuid())
  userId                     String                    @map("userId")
  date                       DateTime                  @db.Date @map("fecha")
  clockInAt                  DateTime                  @map("horaEntrada")
  clockOutAt                 DateTime?                 @map("horaSalida")
  orderCode                  String                    @map("codigoOrden")
  note                       String?                   @map("nota")
  regularHours               Float                     @default(0) @map("horasOrdinarias")
  daytimeOvertimeHours       Float                     @default(0) @map("heDiurna")
  nighttimeOvertimeHours     Float                     @default(0) @map("heNocturna")
  sundayOvertimeHours        Float                     @default(0) @map("heDominical")
  nightSundayOvertimeHours   Float                     @default(0) @map("heNoctDominical")
  nightSurchargeHours        Float                     @default(0) @map("recNocturno")
  sundaySurchargeHours       Float                     @default(0) @map("recDominical")
  nightSundaySurchargeHours  Float                     @default(0) @map("recNoctDominical")
  clockInLat                 Float?                    @map("latEntrada")
  clockInLng                 Float?                    @map("lngEntrada")
  clockOutLat                Float?                    @map("latSalida")
  clockOutLng                Float?                    @map("lngSalida")
  createdAt                  DateTime                  @default(now()) @map("createdAt")
  updatedAt                  DateTime                  @updatedAt @map("updatedAt")
  reports                    ReportCoordinatorShift[]
  user                       User                      @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("TurnoCoordinador")
}

model ReportCoordinatorShift {
  id                  String           @id @default(cuid())
  reportId            String           @map("reporteId")
  coordinatorShiftId  String           @map("turnoCoordinadorId")
  report              Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  coordinatorShift    CoordinatorShift @relation(fields: [coordinatorShiftId], references: [id], onDelete: Cascade)

  @@unique([reportId, coordinatorShiftId])
  @@map("ReporteTurnoCoordinador")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model entregas {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_entrega            String    @unique
  fecha_entrega         DateTime  @db.Date
  id_envio              String?
  responsable           String
  monto_entregado       Decimal   @default(0) @db.Decimal(14, 2)
  saldo_total_entregado Decimal?  @default(0) @db.Decimal(14, 2)
  aceptar               Boolean?  @default(false)
  firma                 String?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)

  @@index([fecha_entrega], map: "idx_mc_entregas_fecha")
  @@index([responsable], map: "idx_mc_entregas_responsable")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model envios {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_envio    String                      @unique
  fecha       DateTime                    @db.Date
  responsable String
  monto       Decimal                     @default(0) @db.Decimal(14, 2)
  sector      Unsupported("sector_type")?
  comprobante String?
  observacion String?
  created_at  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                   @default(now()) @db.Timestamptz(6)

  @@index([responsable], map: "idx_mc_envios_responsable")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model facturas {
  id                String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_factura        String                        @unique
  num_factura       String?
  fecha_factura     DateTime?                     @db.Date
  monto_factura     Decimal                       @default(0) @db.Decimal(14, 2)
  responsable       String
  tipo_servicio     String?
  tipo_factura      String?
  nit_factura       String?
  razon_social      String?
  nombre_bia        Boolean?                      @default(false)
  observacion       String?
  adjuntar_factura  String?
  url               String?
  estado            Unsupported("estado_factura") @default(dbgenerated("'Pendiente'::micaja.estado_factura"))
  verificado        Boolean?                      @default(false)
  ciudad            String?
  sector            Unsupported("sector_type")?
  centro_costo      String?
  info_centro_costo String?
  fecha_creacion    DateTime?                     @default(now()) @db.Timestamptz(6)
  created_at        DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?                     @default(now()) @db.Timestamptz(6)

  @@index([estado], map: "idx_mc_facturas_estado")
  @@index([fecha_factura], map: "idx_mc_facturas_fecha")
  @@index([responsable], map: "idx_mc_facturas_responsable")
  @@index([sector], map: "idx_mc_facturas_sector")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model gastos_generales {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_gasto    String                      @unique
  fecha       DateTime                    @db.Date
  descripcion String?
  monto       Decimal                     @default(0) @db.Decimal(14, 2)
  categoria   String?
  responsable String?
  sector      Unsupported("sector_type")?
  comprobante String?
  estado      String?                     @default("Pendiente")
  created_at  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                   @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model gastos_grupos {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_gasto    String                      @unique
  fecha       DateTime                    @db.Date
  grupo       String?
  descripcion String?
  monto       Decimal                     @default(0) @db.Decimal(14, 2)
  responsable String?
  sector      Unsupported("sector_type")?
  estado      String?                     @default("Pendiente")
  created_at  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                   @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model legalizaciones {
  id             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_reporte     String                      @unique
  fecha          DateTime                    @db.Date
  coordinador    String
  sector         Unsupported("sector_type")?
  total          Decimal?                    @default(0) @db.Decimal(14, 2)
  total_aprobado Decimal?                    @default(0) @db.Decimal(14, 2)
  estado         String?                     @default("Pendiente")
  observacion    String?
  url_reporte    String?
  created_at     DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?                   @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sesiones_bot {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id        String    @unique
  responsable    String?
  estado         String?
  datos_temp     Json?
  ultimo_mensaje DateTime? @default(now()) @db.Timestamptz(6)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usuarios {
  id               String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  responsable      String
  correo           String                     @unique
  telefono         String?
  rol              Unsupported("rol_type")    @default(dbgenerated("'user'::micaja.rol_type"))
  user_active      Boolean                    @default(true)
  area             String?
  cargo            String?
  cedula           String?
  pin              String?                    @default("1234")
  sector           Unsupported("sector_type") @default(dbgenerated("'Bogota'::micaja.sector_type"))
  telegram_chat_id String?
  created_at       DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?                  @default(now()) @db.Timestamptz(6)

  @@index([correo], map: "idx_mc_usuarios_correo")
  @@index([rol], map: "idx_mc_usuarios_rol")
  @@index([sector], map: "idx_mc_usuarios_sector")
}

enum Role {
  TECNICO
  COORDINADOR
  COORDINADOR_INTERIOR
  MANAGER
  ADMIN
  SUPPLY
  PENDIENTE
}

enum Zone {
  BOGOTA
  COSTA
  INTERIOR

  @@map("Zona")
}

enum JobTitle {
  TECNICO
  ALMACENISTA

  @@map("Cargo")
}

enum ApprovalStatus {
  PENDIENTE
  APROBADA
  NO_APROBADA

  @@map("EstadoAprobacion")
}

enum DayType {
  TRABAJO
  DESCANSO
  DISPONIBLE
  DIA_FAMILIA
  INCAPACITADO
  VACACIONES
  MEDIO_CUMPLE

  @@map("TipoDia")
}
