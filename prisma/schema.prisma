generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  documentNumber    String             @unique @map("document_number")
  fullName          String             @map("full_name")
  email             String             @unique
  password          String
  role              Role               @default(TECNICO)
  zone              Zone               @default(BOGOTA)
  jobTitle          JobTitle           @default(TECNICO) @map("job_title")
  teamFilter        String             @default("TODOS") @map("team_filter")
  isActive          Boolean            @default(true) @map("is_active")
  photoUrl          String?            @map("photo_url")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  availabilities    Availability[]
  tripRecords       TripRecord[]
  shiftSchedules    ShiftSchedule[]
  pushSubscriptions PushSubscription[]
  reportsCreated    Report[]           @relation("ReportesCreados")
  shifts            Shift[]
  coordinatorShifts CoordinatorShift[]

  @@map("users")
}

model Shift {
  id                         String        @id @default(cuid())
  userId                     String        @map("user_id")
  date                       DateTime      @db.Date
  weekday                    String?
  clockInAt                  DateTime      @map("clock_in_at")
  clockOutAt                 DateTime?     @map("clock_out_at")
  clockInLat                 Float?        @map("clock_in_lat")
  clockInLng                 Float?        @map("clock_in_lng")
  clockOutLat                Float?        @map("clock_out_lat")
  clockOutLng                Float?        @map("clock_out_lng")
  startPhotoUrl              String?       @map("start_photo_url")
  endPhotoUrl                String?       @map("end_photo_url")
  regularHours               Float         @default(0) @map("regular_hours")
  daytimeOvertimeHours       Float         @default(0) @map("daytime_overtime_hours")
  nighttimeOvertimeHours     Float         @default(0) @map("nighttime_overtime_hours")
  sundayOvertimeHours        Float         @default(0) @map("sunday_overtime_hours")
  nightSundayOvertimeHours   Float         @default(0) @map("night_sunday_overtime_hours")
  nightSurchargeHours        Float         @default(0) @map("night_surcharge_hours")
  sundaySurchargeHours       Float         @default(0) @map("sunday_surcharge_hours")
  nightSundaySurchargeHours  Float         @default(0) @map("night_sunday_surcharge_hours")
  notes                      String?
  workdayAlertSentAt         DateTime?     @map("workday_alert_sent_at")
  createdAt                  DateTime      @default(now()) @map("created_at")
  updatedAt                  DateTime      @updatedAt @map("updated_at")
  reports                    ReportShift[]
  user                       User          @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("shifts")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model ShiftSchedule {
  id        String               @id @default(cuid())
  userId    String               @map("user_id")
  date      DateTime             @db.Date
  shiftCode String               @map("shift_code")
  dayType   DayType?             @default(TRABAJO) @map("day_type")
  startTime String?              @map("start_time")
  endTime   String?              @map("end_time")
  createdAt DateTime             @default(now()) @map("created_at")
  user      User                 @relation(fields: [userId], references: [id])
  reports   ReportAvailability[]

  @@unique([userId, date])
  @@map("shift_schedules")
}

model Holiday {
  id    String   @id @default(cuid())
  date  DateTime @unique @db.Date
  name  String

  @@map("holidays")
}

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  amount    Float    @default(80000)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("availabilities")
}

model TripRecord {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  type              String
  driveFileId       String?          @map("drive_file_id")
  driveUrl          String?          @map("drive_url")
  driveFileIdFinal  String?          @map("drive_file_id_final")
  driveUrlFinal     String?          @map("drive_url_final")
  base64Fallback    String?          @map("base64_fallback")
  startKm           Float?           @map("start_km")
  endKm             Float?           @map("end_km")
  startLat          Float?           @map("start_lat")
  startLng          Float?           @map("start_lng")
  endLat            Float?           @map("end_lat")
  endLng            Float?           @map("end_lng")
  notes             String?
  approvalStatus    ApprovalStatus   @default(PENDIENTE) @map("approval_status")
  approvedBy        String?          @map("approved_by")
  approvedAt        DateTime?        @map("approved_at")
  approvalNote      String?          @map("approval_note")
  createdAt         DateTime         @default(now()) @map("created_at")
  user              User             @relation(fields: [userId], references: [id])
  reports           ReportTrip[]

  @@map("trip_records")
}

model Report {
  id                          String                    @id @default(cuid())
  name                        String
  startDate                   DateTime                  @db.Date @map("start_date")
  endDate                     DateTime                  @db.Date @map("end_date")
  createdBy                   String                    @map("created_by")
  zone                        String?
  createdAt                   DateTime                  @default(now()) @map("created_at")
  createdByUser               User                      @relation("ReportesCreados", fields: [createdBy], references: [id])
  availabilitiesIncluded      ReportAvailability[]
  tripsIncluded               ReportTrip[]
  shiftsIncluded              ReportShift[]
  coordinatorShiftsIncluded   ReportCoordinatorShift[]

  @@index([zone])
  @@index([createdAt])
  @@map("reports")
}

model ReportShift {
  id        String  @id @default(cuid())
  reportId  String  @map("report_id")
  shiftId   String  @map("shift_id")
  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  shift     Shift   @relation(fields: [shiftId], references: [id])

  @@unique([reportId, shiftId])
  @@map("report_shifts")
}

model ReportTrip {
  id            String     @id @default(cuid())
  reportId      String     @map("report_id")
  tripRecordId  String     @map("trip_record_id")
  tripRecord    TripRecord @relation(fields: [tripRecordId], references: [id])
  report        Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, tripRecordId])
  @@map("report_trips")
}

model ReportAvailability {
  id              String        @id @default(cuid())
  reportId        String        @map("report_id")
  shiftScheduleId String        @map("shift_schedule_id")
  shiftSchedule   ShiftSchedule @relation(fields: [shiftScheduleId], references: [id])
  report          Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, shiftScheduleId])
  @@map("report_availabilities")
}

model CoordinatorShift {
  id                         String                    @id @default(cuid())
  userId                     String                    @map("user_id")
  date                       DateTime                  @db.Date
  clockInAt                  DateTime                  @map("clock_in_at")
  clockOutAt                 DateTime?                 @map("clock_out_at")
  orderCode                  String                    @map("order_code")
  note                       String?
  regularHours               Float                     @default(0) @map("regular_hours")
  daytimeOvertimeHours       Float                     @default(0) @map("daytime_overtime_hours")
  nighttimeOvertimeHours     Float                     @default(0) @map("nighttime_overtime_hours")
  sundayOvertimeHours        Float                     @default(0) @map("sunday_overtime_hours")
  nightSundayOvertimeHours   Float                     @default(0) @map("night_sunday_overtime_hours")
  nightSurchargeHours        Float                     @default(0) @map("night_surcharge_hours")
  sundaySurchargeHours       Float                     @default(0) @map("sunday_surcharge_hours")
  nightSundaySurchargeHours  Float                     @default(0) @map("night_sunday_surcharge_hours")
  clockInLat                 Float?                    @map("clock_in_lat")
  clockInLng                 Float?                    @map("clock_in_lng")
  clockOutLat                Float?                    @map("clock_out_lat")
  clockOutLng                Float?                    @map("clock_out_lng")
  createdAt                  DateTime                  @default(now()) @map("created_at")
  updatedAt                  DateTime                  @updatedAt @map("updated_at")
  reports                    ReportCoordinatorShift[]
  user                       User                      @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("coordinator_shifts")
}

model ReportCoordinatorShift {
  id                  String           @id @default(cuid())
  reportId            String           @map("report_id")
  coordinatorShiftId  String           @map("coordinator_shift_id")
  report              Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  coordinatorShift    CoordinatorShift @relation(fields: [coordinatorShiftId], references: [id], onDelete: Cascade)

  @@unique([reportId, coordinatorShiftId])
  @@map("report_coordinator_shifts")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model entregas {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_entrega            String    @unique
  fecha_entrega         DateTime  @db.Date
  id_envio              String?
  responsable           String
  monto_entregado       Decimal   @default(0) @db.Decimal(14, 2)
  saldo_total_entregado Decimal?  @default(0) @db.Decimal(14, 2)
  aceptar               Boolean?  @default(false)
  firma                 String?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)

  @@index([fecha_entrega], map: "idx_mc_entregas_fecha")
  @@index([responsable], map: "idx_mc_entregas_responsable")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model envios {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_envio    String                      @unique
  fecha       DateTime                    @db.Date
  responsable String
  monto       Decimal                     @default(0) @db.Decimal(14, 2)
  sector      Unsupported("sector_type")?
  comprobante String?
  observacion String?
  created_at  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                   @default(now()) @db.Timestamptz(6)

  @@index([responsable], map: "idx_mc_envios_responsable")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model facturas {
  id                String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_factura        String                        @unique
  num_factura       String?
  fecha_factura     DateTime?                     @db.Date
  monto_factura     Decimal                       @default(0) @db.Decimal(14, 2)
  responsable       String
  tipo_servicio     String?
  tipo_factura      String?
  nit_factura       String?
  razon_social      String?
  nombre_bia        Boolean?                      @default(false)
  observacion       String?
  adjuntar_factura  String?
  url               String?
  estado            Unsupported("estado_factura") @default(dbgenerated("'Pendiente'::micaja.estado_factura"))
  verificado        Boolean?                      @default(false)
  ciudad            String?
  sector            Unsupported("sector_type")?
  centro_costo      String?
  info_centro_costo String?
  fecha_creacion    DateTime?                     @default(now()) @db.Timestamptz(6)
  created_at        DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?                     @default(now()) @db.Timestamptz(6)

  @@index([estado], map: "idx_mc_facturas_estado")
  @@index([fecha_factura], map: "idx_mc_facturas_fecha")
  @@index([responsable], map: "idx_mc_facturas_responsable")
  @@index([sector], map: "idx_mc_facturas_sector")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model gastos_generales {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_gasto    String                      @unique
  fecha       DateTime                    @db.Date
  descripcion String?
  monto       Decimal                     @default(0) @db.Decimal(14, 2)
  categoria   String?
  responsable String?
  sector      Unsupported("sector_type")?
  comprobante String?
  estado      String?                     @default("Pendiente")
  created_at  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                   @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model gastos_grupos {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_gasto    String                      @unique
  fecha       DateTime                    @db.Date
  grupo       String?
  descripcion String?
  monto       Decimal                     @default(0) @db.Decimal(14, 2)
  responsable String?
  sector      Unsupported("sector_type")?
  estado      String?                     @default("Pendiente")
  created_at  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                   @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model legalizaciones {
  id             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_reporte     String                      @unique
  fecha          DateTime                    @db.Date
  coordinador    String
  sector         Unsupported("sector_type")?
  total          Decimal?                    @default(0) @db.Decimal(14, 2)
  total_aprobado Decimal?                    @default(0) @db.Decimal(14, 2)
  estado         String?                     @default("Pendiente")
  observacion    String?
  url_reporte    String?
  created_at     DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?                   @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sesiones_bot {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id        String    @unique
  responsable    String?
  estado         String?
  datos_temp     Json?
  ultimo_mensaje DateTime? @default(now()) @db.Timestamptz(6)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usuarios {
  id               String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  responsable      String
  correo           String                     @unique
  telefono         String?
  rol              Unsupported("rol_type")    @default(dbgenerated("'user'::micaja.rol_type"))
  user_active      Boolean                    @default(true)
  area             String?
  cargo            String?
  cedula           String?
  pin              String?                    @default("1234")
  sector           Unsupported("sector_type") @default(dbgenerated("'Bogota'::micaja.sector_type"))
  telegram_chat_id String?
  created_at       DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?                  @default(now()) @db.Timestamptz(6)

  @@index([correo], map: "idx_mc_usuarios_correo")
  @@index([rol], map: "idx_mc_usuarios_rol")
  @@index([sector], map: "idx_mc_usuarios_sector")
}

enum Role {
  TECNICO
  COORDINADOR
  COORDINADOR_INTERIOR
  MANAGER
  ADMIN
  SUPPLY
  PENDIENTE
}

enum Zone {
  BOGOTA
  COSTA
  INTERIOR
}

enum JobTitle {
  TECNICO
  ALMACENISTA
}

enum ApprovalStatus {
  PENDIENTE
  APROBADA
  NO_APROBADA
}

enum DayType {
  TRABAJO
  DESCANSO
  DISPONIBLE
  DIA_FAMILIA
  INCAPACITADO
  VACACIONES
  MEDIO_CUMPLE
}
