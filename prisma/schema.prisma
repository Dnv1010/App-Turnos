generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TECNICO
  COORDINADOR
  COORDINADOR_INTERIOR
  MANAGER
  ADMIN
}

enum Zona {
  BOGOTA
  COSTA
  INTERIOR
}

enum Cargo {
  TECNICO
  ALMACENISTA
}

enum EstadoAprobacion {
  PENDIENTE
  APROBADA
  NO_APROBADA
}

enum TipoDia {
  TRABAJO
  DESCANSO
  DISPONIBLE
  DIA_FAMILIA
  INCAPACITADO
  VACACIONES
  MEDIO_CUMPLE
}

model User {
  id             String          @id @default(cuid())
  cedula         String          @unique
  nombre         String
  email          String          @unique
  password       String
  role           Role            @default(TECNICO)
  zona           Zona            @default(BOGOTA)
  cargo          Cargo           @default(TECNICO)
  filtroEquipo   String          @default("TODOS")
  isActive       Boolean         @default(true)
  fotoUrl        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  turnos         Turno[]
  mallaTurnos    MallaTurno[]
  disponibilidades Disponibilidad[]
  fotoRegistros  FotoRegistro[]
  pushSubscriptions PushSubscription[]
  reportesCreados Reporte[] @relation("ReportesCreados")
  turnosCoordinador TurnoCoordinador[]
  accounts       Account[]
  sessions       Session[]
}

model Turno {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fecha          DateTime @db.Date
  horaEntrada    DateTime
  horaSalida     DateTime?
  latEntrada     Float?
  lngEntrada     Float?
  latSalida      Float?
  lngSalida      Float?
  startPhotoUrl  String?
  endPhotoUrl    String?
  horasOrdinarias Float   @default(0)
  heDiurna       Float    @default(0)
  heNocturna     Float    @default(0)
  heDominical    Float    @default(0)
  heNoctDominical Float   @default(0)
  recNocturno    Float    @default(0)
  recDominical   Float    @default(0)
  recNoctDominical Float  @default(0)
  observaciones  String?
  jornadaAlertaPushSentAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reportes       ReporteTurno[]

  @@index([userId, fecha])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model MallaTurno {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  fecha      DateTime  @db.Date
  valor      String
  tipo       TipoDia?  @default(TRABAJO)
  horaInicio String?
  horaFin    String?
  createdAt  DateTime  @default(now())
  reportes   ReporteDisponibilidad[]

  @@unique([userId, fecha])
}

model Festivo {
  id     String   @id @default(cuid())
  fecha  DateTime @db.Date @unique
  nombre String
}

model Disponibilidad {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  fecha     DateTime @db.Date
  monto     Float    @default(80000)
  createdAt DateTime @default(now())

  @@unique([userId, fecha])
}

model FotoRegistro {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  tipo               String
  driveFileId        String?
  driveUrl           String?
  driveFileIdFinal   String?
  driveUrlFinal      String?
  base64Fallback     String?           @db.Text
  kmInicial          Float?
  kmFinal            Float?
  latInicial         Float?
  lngInicial         Float?
  latFinal           Float?
  lngFinal           Float?
  observaciones      String?
  estadoAprobacion   EstadoAprobacion  @default(PENDIENTE)
  aprobadoPor        String?
  fechaAprobacion    DateTime?
  notaAprobacion     String?
  createdAt          DateTime          @default(now())
  reportes           ReporteForaneo[]
}

model Reporte {
  id                        String                   @id @default(cuid())
  nombre                    String
  fechaInicio               DateTime                 @db.Date
  fechaFin                  DateTime                 @db.Date
  creadoPor                 String
  creadoPorUser             User                     @relation("ReportesCreados", fields: [creadoPor], references: [id])
  zona                      String?
  createdAt                 DateTime                 @default(now())
  turnosIncluidos           ReporteTurno[]
  foraneosIncluidos         ReporteForaneo[]
  disponibilidadesIncluidas ReporteDisponibilidad[]
  turnosCoordinadorIncluidos ReporteTurnoCoordinador[]

  @@index([zona])
  @@index([createdAt])
}

model ReporteTurno {
  id        String  @id @default(cuid())
  reporteId String
  reporte   Reporte @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  turnoId   String
  turno     Turno   @relation(fields: [turnoId], references: [id], onDelete: Restrict)

  @@unique([reporteId, turnoId])
}

model ReporteForaneo {
  id             String       @id @default(cuid())
  reporteId      String
  reporte        Reporte      @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  fotoRegistroId String
  fotoRegistro   FotoRegistro @relation(fields: [fotoRegistroId], references: [id], onDelete: Restrict)

  @@unique([reporteId, fotoRegistroId])
}

model ReporteDisponibilidad {
  id           String     @id @default(cuid())
  reporteId    String
  reporte      Reporte    @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  mallaTurnoId String
  mallaTurno   MallaTurno @relation(fields: [mallaTurnoId], references: [id], onDelete: Restrict)

  @@unique([reporteId, mallaTurnoId])
}

model TurnoCoordinador {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fecha          DateTime @db.Date
  horaEntrada    DateTime
  horaSalida     DateTime?
  codigoOrden    String
  nota           String?
  horasOrdinarias Float   @default(0)
  heDiurna       Float    @default(0)
  heNocturna     Float    @default(0)
  heDominical    Float    @default(0)
  heNoctDominical Float   @default(0)
  recNocturno    Float    @default(0)
  recDominical   Float    @default(0)
  recNoctDominical Float  @default(0)
  latEntrada     Float?
  lngEntrada     Float?
  latSalida      Float?
  lngSalida      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reportes       ReporteTurnoCoordinador[]

  @@index([userId, fecha])
}

model ReporteTurnoCoordinador {
  id                 String           @id @default(cuid())
  reporteId          String
  reporte            Reporte          @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  turnoCoordinadorId String
  turnoCoordinador   TurnoCoordinador @relation(fields: [turnoCoordinadorId], references: [id], onDelete: Cascade)

  @@unique([reporteId, turnoCoordinadorId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
