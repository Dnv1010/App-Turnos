DATABASE_URL="postgresql://user:password@localhost:5432/app_turnos_bia"
# En local: usa http://localhost:3000 (sin / al final). En Vercel NO definas NEXTAUTH_URL; se genera automáticamente.
NEXTAUTH_URL="http://localhost:3000"
# OBLIGATORIO en Vercel. Genera uno con: openssl rand -base64 32. Aplícalo a Production, Preview y Development.
NEXTAUTH_SECRET="your-secret-here"
# Solo necesarias si usas login con Google. Si no las configuras, la app usa solo Credenciales (email + PIN).
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_DRIVE_FOLDER_ID="your-drive-folder-id"
