# === SUPABASE ===
# URL del proyecto Supabase (dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
# Anon/Public key (dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Service role key (dashboard -> Settings -> API) - SOLO servidor, NUNCA exponerla al cliente
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# === DATABASE (Supabase PostgreSQL) ===
# Connection string con pooler (pgbouncer) para serverless (dashboard -> Settings -> Database)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connection string directa sin pooler para migraciones (dashboard -> Settings -> Database)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# === GOOGLE SHEETS (SE MANTIENE) ===
# ID del spreadsheet, email y private_key del JSON de la cuenta de servicio
GOOGLE_SHEETS_ID="your-spreadsheet-id"
GOOGLE_SHEETS_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === NOTIFICACIONES ===
# Resend API key para enviar emails (https://resend.com)
RESEND_API_KEY="re_xxxxx"
# Email del administrador para notificaciones
ADMIN_EMAIL="admin@biaenergy.co"

# === WEB PUSH (NOTIFICACIONES PUSH) ===
# Claves VAPID para notificaciones push. Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_PRIVATE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_CONTACT_EMAIL="admin@biaenergy.co"

# === NOTA IMPORTANTE ===
# Variables eliminadas en migración a Supabase:
# - NEXTAUTH_URL (ya no se usa NextAuth)
# - NEXTAUTH_SECRET (ya no se usa NextAuth)
# - GOOGLE_CLIENT_ID (ahora se configura en Supabase Dashboard -> Auth -> Providers)
# - GOOGLE_CLIENT_SECRET (ahora se configura en Supabase Dashboard -> Auth -> Providers)
# - GOOGLE_DRIVE_FOLDER_ID (reemplazado por Supabase Storage buckets)
# - GOOGLE_PRIVATE_KEY (para Drive, ya no se usa)
# - GOOGLE_SERVICE_ACCOUNT_EMAIL (para Drive, ya no se usa)
